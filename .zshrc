# ============================================================================
# Zsh 互動式 Shell 配置 (.zshrc)
# ============================================================================
# 注：此檔案在每次開啟互動式 shell 時都會執行
# ============================================================================

# 確保 Homebrew PATH 在 vterm 或其他非標準 shell 中可用
if [[ -d /opt/homebrew/bin ]]; then
  export PATH="/opt/homebrew/bin:$PATH"
elif [[ -d /usr/local/bin ]]; then
  export PATH="/usr/local/bin:$PATH"
fi

# 使用者本地執行檔（例如 claude）
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"

# ────────────────────────────────────────────────────────────────────────────
# 語系設定
# ────────────────────────────────────────────────────────────────────────────
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# ────────────────────────────────────────────────────────────────────────────
# Homebrew 環境變量
# ────────────────────────────────────────────────────────────────────────────
BREW_PREFIX=$(brew --prefix)
export DYLD_LIBRARY_PATH="${BREW_PREFIX}/lib:${DYLD_LIBRARY_PATH}"
export PKG_CONFIG_PATH="${BREW_PREFIX}/lib/pkgconfig:${PKG_CONFIG_PATH}"

# ────────────────────────────────────────────────────────────────────────────
# 補全系統初始化（必須在插件載入前）
# ────────────────────────────────────────────────────────────────────────────
# 設定 Homebrew 的補全路徑
if type brew &>/dev/null; then
  FPATH="${BREW_PREFIX}/share/zsh/site-functions:${FPATH}"
fi

# 啟用 zsh 原生補全系統
autoload -Uz compinit
compinit

# ────────────────────────────────────────────────────────────────────────────
# 命令歷史配置
# ────────────────────────────────────────────────────────────────────────────
# 記憶體中保留的命令數
HISTSIZE=100000

# 儲存到檔案（~/.zsh_history）的命令數
SAVEHIST=100000

# 啟用歷史相關選項
setopt APPEND_HISTORY          # 新命令附加到歷史檔案，而不是覆寫
setopt SHARE_HISTORY           # 多個終端視窗即時共享歷史
setopt HIST_IGNORE_DUPS        # 忽略連續的重複命令
setopt HIST_IGNORE_ALL_DUPS    # 忽略任何重複命令（保留最新一筆）
setopt HIST_EXPIRE_DUPS_FIRST  # 當歷史滿時優先刪除重複的舊命令
setopt EXTENDED_HISTORY        # 在歷史檔案中記錄時間戳

# ────────────────────────────────────────────────────────────────────────────
# 單詞編輯功能設定
# ────────────────────────────────────────────────────────────────────────────
# 載入單詞風格功能
autoload -Uz select-word-style

# 設定為 bash 風格：以 / - . 等符號為單詞邊界（更符合程式設計師習慣）
select-word-style bash

# ────────────────────────────────────────────────────────────────────────────
# Zsh 插件與擴展功能
# ────────────────────────────────────────────────────────────────────────────
# 自動建議插件：根據歷史記錄提供命令建議
source ${BREW_PREFIX}/share/zsh-autosuggestions/zsh-autosuggestions.zsh

# 語法高亮插件：提供命令的實時語法高亮
source ${BREW_PREFIX}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Fzf 插件：設定按鍵綁定和模糊補全功能
source <(fzf --zsh)

# ────────────────────────────────────────────────────────────────────────────
# 命令別名定義
# ────────────────────────────────────────────────────────────────────────────
# 歷史命令快速訪問
alias h='history'

# 啟用 ls 顏色顯示（macOS BSD ls 使用 -G 標誌）
alias ls='ls -G'
alias ll='ls -al'

# ────────────────────────────────────────────────────────────────────────────
# 提示符與外觀設定
# ────────────────────────────────────────────────────────────────────────────
# 初始化 Starship 提示符（美觀的 shell 提示符主題）
eval "$(starship init zsh)"
